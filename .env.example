# NEMESIS PRO - PRODUCTION ENVIRONMENT TEMPLATE

# 1. AI API Keys (Used for OSINT clustering, report generation)
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2

# 2. Block Explorer / Tracing API Keys (REQUIRED for multi-chain support without rate limiting)
ETHERSCAN_API_KEY=your_etherscan_key_1,your_etherscan_key_2
BSCSCAN_API_KEY=your_bscscan_key_1
POLYGONSCAN_API_KEY=your_polygonscan_key_1
TRONSCAN_API_KEY=your_tronscan_key_1

# 3. Database
DATABASE_MONGO_URL=mongodb://mongo:27017

# 4. Engine Configuration
TRACE_MAX_DEPTH=15
CONCURRENCY_LIMIT=100
